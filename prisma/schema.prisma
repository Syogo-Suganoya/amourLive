generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String          @id @default(uuid())
  loginId    String          @unique
  password   String
  name       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  characters UserCharacter[]
}

model Character {
  id             String          @id
  name           String
  era            String          @default("modern")
  personality    String
  speechStyle    String
  coreRules      String
  location       String          @default("")
  userCharacters UserCharacter[]
}

model UserCharacter {
  id          String            @id @default(uuid())
  userId      String
  characterId String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memories    CharacterMemory[]
  state       CharacterState?
  logs        ConversationLog[]
  events      EventHistory[]
  character   Character         @relation(fields: [characterId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@unique([userId, characterId])
}

model CharacterState {
  id                String        @id @default(uuid())
  userCharacterId   String        @unique
  affection         Int           @default(0)
  trust             Int           @default(0)
  relationshipStage String        @default("stranger")
  currentLocation   String        @default("")
  flags             String        @default("{}")
  updatedAt         DateTime      @updatedAt
  userCharacter     UserCharacter @relation(fields: [userCharacterId], references: [id])
}

model CharacterMemory {
  id              String        @id @default(uuid())
  userCharacterId String
  category        String
  content         String
  importance      Int           @default(1)
  createdAt       DateTime      @default(now())
  userCharacter   UserCharacter @relation(fields: [userCharacterId], references: [id])
}

model ConversationLog {
  id              String        @id @default(uuid())
  userCharacterId String
  role            String
  content         String
  createdAt       DateTime      @default(now())
  userCharacter   UserCharacter @relation(fields: [userCharacterId], references: [id])
}

model EventHistory {
  id              String        @id @default(uuid())
  userCharacterId String
  eventName       String
  occurredAt      DateTime      @default(now())
  userCharacter   UserCharacter @relation(fields: [userCharacterId], references: [id])
}
